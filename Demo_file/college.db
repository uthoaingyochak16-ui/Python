import sqlite3

# 1. Connect to the database (creates the file if it doesn't exist)
connection = sqlite3.connect('college.db')

# 2. Create a cursor object (used to execute SQL commands)
cursor = connection.cursor()

# 3. Create a table
cursor.execute('''
    CREATE TABLE IF NOT EXISTS student (
        student_id INTEGER PRIMARY KEY,
        surname TEXT,
        age INTEGER,
        grade_point REAL
    )
''')

# 4. Insert data
cursor.execute("INSERT INTO student VALUES (1, 'Smith', 19, 4.0)")

# 5. Commit changes and close
connection.commit()
connection.close()